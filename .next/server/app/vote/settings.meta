{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/vote/layout,_N_T_/vote/settings/layout,_N_T_/vote/settings/page,_N_T_/vote/settings"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/vote/settings/__PAGE__",
    "/vote/settings",
    "/vote",
    "/_index",
    "/_head"
  ]
}