{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/vote/layout,_N_T_/vote/confirmation/layout,_N_T_/vote/confirmation/page,_N_T_/vote/confirmation"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/vote/confirmation/__PAGE__",
    "/vote/confirmation",
    "/vote",
    "/_index",
    "/_head"
  ]
}