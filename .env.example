# Recommended for most uses
DATABASE_URL="postgresql://user:password@host/database_name?sslmode=require"

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED="postgresql://user:password@host/database_name?sslmode=require"

# Parameters for constructing your own connection string
PGHOST="host"
PGHOST_UNPOOLED="host_unpooled"
PGUSER="user"
PGDATABASE="database_name"
PGPASSWORD="password"

# Parameters for Vercel Postgres Templates
POSTGRES_URL="postgresql://user:password@host/database_name?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host_unpooled/database_name?sslmode=require"
POSTGRES_USER="user"
POSTGRES_HOST="host"
POSTGRES_PASSWORD="password"
POSTGRES_DATABASE="database_name"
POSTGRES_URL_NO_SSL="postgresql://user:password@host/database_name"
POSTGRES_PRISMA_URL="postgresql://user:password@host/database_name?sslmode=require"
